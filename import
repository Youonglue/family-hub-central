import { randomUUID } from "node:crypto";
import { db } from "../db.js";

export default async function mealRoutes(app: any, opts: any) {
  app.get("/recipes", async (req: any) => {
    const cat = req.query.category;
    return cat ? db.prepare("SELECT * FROM recipes WHERE category = ? COLLATE NOCASE").all(cat) : db.prepare("SELECT * FROM recipes ORDER BY name").all();
  });
  app.get("/plan", async () => db.prepare(`SELECT mp.*, r.name as recipe_name, r.category as recipe_category, r.image_url, r.instructions, r.ingredients as recipe_ingredients FROM meal_plan mp LEFT JOIN recipes r ON mp.recipe_id = r.id`).all());
  app.post("/plan", async (req: any) => {
    const date = req.body.plan_date.split('T')[0];
    db.prepare(`INSERT INTO meal_plan (id, plan_date, meal, recipe_id, created_at) VALUES (?,?,?,?,datetime('now')) ON CONFLICT(plan_date, meal) DO UPDATE SET recipe_id = excluded.recipe_id`).run(randomUUID(), date, req.body.meal, req.body.recipe_id);
    opts.broadcast("meal-plan"); return { success: true };
  });
}
